{
  "name": "shopsmart-backend",
  "version": "1.0.0",
  "description": "Backend API for ShopSmart",
  "type": "module",
  "main": "src/index.js",

  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",

    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",

    "lint": "eslint src/ --max-warnings 0 || true",
    "lint:fix": "eslint src/ --fix || true",

    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },

  "dependencies": {
    "@prisma/client": "^5.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },

  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.1",
    "prisma": "^5.8.0",
    "supertest": "^6.3.4"
  }
}